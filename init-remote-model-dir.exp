#!/usr/bin/expect -f
# 在远程服务器创建 ~/aigc-security-model 目录（密码与 lab 部署一致）
set timeout 30
set remote_host "10.102.32.144"
set remote_user "lab426"
set remote_pass "426"

spawn ssh -o StrictHostKeyChecking=no ${remote_user}@${remote_host} "mkdir -p ~/aigc-security-model && echo OK"
expect {
    "password:" { send "${remote_pass}\r"; exp_continue }
    eof
}
